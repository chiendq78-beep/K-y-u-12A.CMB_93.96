rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    match /classmates/{classmateId} {
      allow read, write: if true;
    }
    match /collectivePhotos/{photoId} {
      allow read, write: if true;
    }
    match /memoryPhotos/{memoryId} {
      allow read, write: if true;
    }
    match /memoryVideos/{videoId} {
      allow read, write: if true;
    }
    match /comments/{commentId} {
      allow read, write: if true;
    }
    match /collectiveAlbums/{albumId} {
      allow read, write: if true;
    }
    match /guestbook/{entryId} {
      allow read, write: if true;
    }
  }
}
